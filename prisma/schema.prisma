generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DBURL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean   @default(false)
  emailVerified       Boolean   @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model Store {
  id                             String                   @id @default(cuid())
  shopDomain                     String                   @unique
  shopName                       String?
  contactEmail                   String?
  themeColor                     String?
  accessToken                    String?
  scope                          String?
  logo                           String?
  isActive                       Boolean                  @default(true)
  installedAt                    DateTime                 @default(now())
  uninstalledAt                  DateTime?
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt
  submissionEmail                String?
  companyWelcomeEmailEnabled     Boolean                  @default(true)
  companyWelcomeEmailTemplate    String?
  storeOwnerName                 String?
  smtpHost                       String?
  smtpPort                       Int?
  smtpSecure                     Boolean                  @default(false)
  smtpUser                       String?
  smtpPassEncrypted              String?
  smtpFromEmail                  String?
  smtpFromName                   String?
  privacyPolicyContent           String?
  privacyPolicylink              String?
  deletedAt                      DateTime?
  autoApproveB2BOnboarding       Boolean                  @default(false)
  defaultCompanyCreditLimit      Decimal?                 @db.Decimal(14, 2)
  orderConfirmationToMainAccount Boolean                  @default(false)
  allowQuickOrderForUser         Boolean                  @default(false)
  blockOrderWhenCreditUnavailable Boolean                 @default(false)
  showDashboardPage              Boolean                  @default(true)
  showLocationsPage              Boolean                  @default(true)
  showUsersPage                  Boolean                  @default(true)
  showOrdersPage                 Boolean                  @default(true)
  showQuickOrderPage             Boolean                  @default(true)
  showWishlistsPage              Boolean                  @default(true)
  showCreditManagementPage       Boolean                  @default(true)
  showNotificationsPage          Boolean                  @default(true)
  showReportsPage                Boolean                  @default(true)
  completedSetupSteps            Json?
  setupFinished                  Boolean                  @default(false)
  plan                           String?
  planKey                        String?
  currencyCode                   String?                  @default("USD")
  invoiceTemplate                String?
  defaultTaxRate                 Decimal?                 @db.Decimal(5, 2) @default(8.00)
  b2bOrders                      B2BOrder[]               @relation("StoreOrders")
  companyAccounts                CompanyAccount[]
  emailTemplates                 EmailTemplates[]         @relation("StoreEmailTemplates")
  formFieldConfigs               FormFieldConfig?
  registrationSubmissions        RegistrationSubmission[]
  users                          User[]
  invitations                    Invitation[]
  quotes                         Quote[]                  @relation("StoreQuotes")

  @@index([shopDomain])
}

model User {
  id                String          @id @default(cuid())
  email             String
  firstName         String?
  lastName          String?
  password          String
  role              UserRole        @default(STORE_USER)
  status            UserStatus      @default(PENDING)
  isActive          Boolean         @default(true)
  shopId            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  companyId         String?
  companyRole       String?
  shopifyCustomerId String?
  userCreditLimit   Decimal?        @db.Decimal(14, 2)
  userCreditUsed    Decimal         @default(0) @db.Decimal(14, 2)
  ordersCreated     B2BOrder[]      @relation("UserCreatedOrders")
  orderActivities   OrderActivity[] @relation("OrderActivityUser")
  quotesCreated     Quote[]         @relation("SalesAgentQuotes")
  company           CompanyAccount? @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: Cascade)
  shop              Store?          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sessions          UserSession[]
  invitation        Invitation?
  salesCompanies    SalesUserCompany[]

  @@unique([shopId, email, role])
  @@index([email])
  @@index([shopId])
  @@index([role])
  @@index([companyId])
}

model UserSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model RegistrationSubmission {
  id                String     @id @default(cuid())
  companyName       String
  email             String
  firstName         String
  lastName          String
  contactTitle      String
  location          Json?
  customFields      Json?
  isPrivacyPolicy   Boolean    @default(false)
  isDisable         Boolean    @default(false)
  shopId            String
  status            UserStatus @default(PENDING)
  shopifyCustomerId String?
  workflowCompleted Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  reviewNotes       String?
  reviewedAt        DateTime?
  shop              Store      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, email])
  @@index([shopId])
  @@index([email])
  @@index([status])
  @@index([shopId, createdAt])
  @@index([createdAt])
}

model CompanyAccount {
  id                 String              @id @default(cuid())
  shopId             String
  shopifyCompanyId   String?
  name               String
  contactName        String?
  contactEmail       String?
  creditLimit        Decimal             @default(0) @db.Decimal(14, 2)
  paymentTerm        String?
  isDisable          Boolean?            @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orders             B2BOrder[]          @relation("CompanyAccountOrders")
  quotes             Quote[]             @relation("CompanyAccountQuotes")
  quoteActivities    QuoteActivity[]
  shop               Store               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  creditTransactions CreditTransaction[]
  users              User[]              @relation("CompanyUsers")
  salesUsers         SalesUserCompany[]

  @@unique([shopId, shopifyCompanyId])
  @@index([shopId])
  @@index([shopifyCompanyId])
}

model FormFieldConfig {
  id        String   @id @default(cuid())
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shopId    String   @unique
  shop      Store    @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id           String         @id @default(cuid())
  name         String
  customerId   String
  shop         String
  locationId   String?
  isSmart      Boolean        @default(false)
  smartType    String?
  lastSyncedAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        WishlistItem[]

  @@index([customerId, shop])
}

model WishlistItem {
  id           String   @id @default(cuid())
  wishlistId   String
  productId    String
  variantId    String
  productTitle String?
  variantTitle String?
  image        String?
  price        Float    @default(0)
  quantity     Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  soldOut      Boolean  @default(false)
  wishlist     Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@index([wishlistId])
}

model Notification {
  id              String   @id @default(cuid())
  receiverId      String?
  adminReceiverId String?
  senderId        String?
  message         String
  activityType    String?
  activeAction    String?
  isRead          Boolean  @default(false)
  shopId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  title           String?
  shopifyOrderId  String?

  @@index([receiverId])
  @@index([senderId])
  @@index([shopId])
}

model OrderPayment {
  id         String    @id @default(cuid())
  orderId    String
  amount     Decimal   @db.Decimal(14, 2)
  method     String?
  status     String    @default("pending")
  receivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  order      B2BOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model B2BOrder {
  id               String         @id @default(cuid())
  companyId        String
  createdByUserId  String
  shopId           String
  shopifyOrderId   String?        @unique
  orderTotal       Decimal        @db.Decimal(14, 2)
  creditUsed       Decimal        @db.Decimal(14, 2)
  paymentStatus    String         @default("pending")
  orderStatus      String         @default("draft")
  paidAmount       Decimal        @default(0) @db.Decimal(14, 2)
  remainingBalance Decimal        @db.Decimal(14, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  paidAt           DateTime?
  userCreditUsed   Decimal        @db.Decimal(14, 2)
  notes            String?
  source           String?
  orderNumber      String?
  customerName     String?
  customerEmail    String?
  customerId       String?
  poNumber         String?
  currencyCode     String         @default("USD")
  subtotal         Decimal        @default(0) @db.Decimal(14, 2)
  discountTotal    Decimal        @default(0) @db.Decimal(14, 2)
  taxAmount        Decimal        @default(0) @db.Decimal(14, 2)
  shippingAmount   Decimal        @default(0) @db.Decimal(14, 2)
  paymentLink      String?
  paymentLinkToken String?        @unique
  paymentLinkAt    DateTime?
  paymentLinkSentAt DateTime?
  company          CompanyAccount @relation("CompanyAccountOrders", fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser    User           @relation("UserCreatedOrders", fields: [createdByUserId], references: [id])
  shop             Store          @relation("StoreOrders", fields: [shopId], references: [id], onDelete: Cascade)
  payments         OrderPayment[]
  items            B2BOrderItem[]
  activities       OrderActivity[]

  @@index([companyId, paymentStatus, orderStatus])
  @@index([companyId])
  @@index([shopId])
  @@index([paymentStatus])
  @@index([createdByUserId])
  @@index([customerEmail])
  @@index([orderNumber])
  @@index([shopId, createdAt])
  @@index([createdAt])
}

model B2BOrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  productTitle String
  variantId    String?
  variantTitle String?
  sku          String?
  image        String?
  quantity     Int
  unitPrice    Decimal  @db.Decimal(14, 2)
  discount     Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal    Decimal  @db.Decimal(14, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  order        B2BOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderActivity {
  id        String   @id @default(cuid())
  orderId   String
  userId    String?
  action    String
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())
  order     B2BOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User?    @relation("OrderActivityUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([userId])
}

model Quote {
  id                String          @id @default(cuid())
  quoteNumber       String          @unique
  shopId            String
  companyId         String
  salesAgentId      String
  title             String
  status            String          @default("draft")
  secureToken       String          @unique
  customerUserId    String?
  customerShopifyId String?
  customerEmail     String
  customerFirstName String?
  customerLastName  String?
  currencyCode      String          @default("USD")
  subtotal          Decimal         @default(0) @db.Decimal(14, 2)
  discountAmount    Decimal         @default(0) @db.Decimal(14, 2)
  discountType      String          @default("FIXED_AMOUNT")
  discountTotal     Decimal         @default(0) @db.Decimal(14, 2)
  shippingAmount    Decimal         @default(0) @db.Decimal(14, 2)
  taxRate           Decimal         @default(0) @db.Decimal(5, 2)
  taxAmount         Decimal         @default(0) @db.Decimal(14, 2)
  totalAmount       Decimal         @default(0) @db.Decimal(14, 2)
  customerNotes     String?
  internalNotes     String?
  customerComments  String?
  expiresAt         DateTime
  sentAt            DateTime?
  viewedAt          DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  convertedAt       DateTime?
  convertedOrderId  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  shop              Store           @relation("StoreQuotes", fields: [shopId], references: [id], onDelete: Cascade)
  company           CompanyAccount  @relation("CompanyAccountQuotes", fields: [companyId], references: [id], onDelete: Cascade)
  salesAgent        User            @relation("SalesAgentQuotes", fields: [salesAgentId], references: [id])
  items             QuoteItem[]
  activities        QuoteActivity[]

  @@index([shopId, createdAt])
  @@index([companyId, status])
  @@index([salesAgentId])
  @@index([customerEmail])
  @@index([expiresAt])
}

model QuoteItem {
  id           String   @id @default(cuid())
  quoteId      String
  productId    String?
  productTitle String
  variantId    String
  variantTitle String?
  sku          String?
  image        String?
  quantity     Int
  unitPrice    Decimal  @db.Decimal(14, 2)
  discount     Decimal  @default(0) @db.Decimal(14, 2)
  totalPrice   Decimal  @db.Decimal(14, 2)
  currencyCode String   @default("USD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quote        Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@index([variantId])
}

model QuoteActivity {
  id             String         @id @default(cuid())
  quoteId        String
  userId         String?
  companyId      String
  customerEmail  String?
  action         String
  message        String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  quote          Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  company        CompanyAccount @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([quoteId, createdAt])
  @@index([companyId, createdAt])
  @@index([userId])
  @@index([action])
}

model CreditTransaction {
  id              String         @id @default(cuid())
  companyId       String
  orderId         String?
  transactionType String
  creditAmount    Decimal        @db.Decimal(14, 2)
  previousBalance Decimal        @db.Decimal(14, 2)
  newBalance      Decimal        @db.Decimal(14, 2)
  notes           String?
  createdBy       String
  createdAt       DateTime       @default(now())
  userId          String?
  company         CompanyAccount @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId])
  @@index([transactionType])
}

model EmailTemplates {
  id                                   String   @id @default(cuid())
  shopId                               String
  customerRegistration                 Boolean? @default(false)
  customerRegistrationSubject          String?
  customerRegistrationTemplate         String?
  customerRegistrationApproved         Boolean? @default(false)
  customerRegistrationApprovedSubject  String?
  customerRegistrationApprovedTemplate String?
  customerRegistrationRejected         Boolean? @default(false)
  customerRegistrationRejectedSubject  String?
  customerRegistrationRejectedTemplate String?
  adminRequest                         Boolean? @default(false)
  adminRequestSubject                  String?
  adminRequestTemplate                 String?
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime @updatedAt
  shop                                 Store    @relation("StoreEmailTemplates", fields: [shopId], references: [id], onDelete: Cascade)
}

enum UserRole {
  SUPER_ADMIN
  STORE_ADMIN
  STORE_USER
  SALES_USER
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model SalesUserCompany {
  id        String         @id @default(cuid())
  userId    String
  companyId String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   CompanyAccount @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model Invitation {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  shopId    String
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop      Store    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([shopId])
}
